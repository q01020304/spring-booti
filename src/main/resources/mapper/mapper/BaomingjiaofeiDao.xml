<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.BaomingjiaofeiDao">
    <select id="selectListVO" resultType="com.entity.vo.BaomingjiaofeiVO">
        SELECT * FROM baomingjiaofei baomingjiaofei WHERE 1 = 1 ${ew.sqlSegment}
    </select>
    <select id="selectVO" resultType="com.entity.vo.BaomingjiaofeiVO">
        SELECT * FROM baomingjiaofei baomingjiaofei WHERE 1 = 1 ${ew.sqlSegment}
    </select>
    <select id="selectListView" resultType="com.entity.view.BaomingjiaofeiView">
        SELECT * FROM baomingjiaofei baomingjiaofei WHERE 1 = 1 ${ew.sqlSegment}
    </select>
    <select id="selectListView" resultType="com.entity.view.BaomingjiaofeiView">
        SELECT * FROM baomingjiaofei baomingjiaofei WHERE 1 = 1 ${ew.sqlSegment}
    </select>
    <select id="selectView" resultType="com.entity.view.BaomingjiaofeiView">
        SELECT * FROM baomingjiaofei baomingjiaofei WHERE 1 = 1 ${ew.sqlSegment}
    </select>
    <select id="paymentSummary" resultType="java.util.Map">
        SELECT
            jiaofeizhuangtai AS status,
            COUNT(1) AS count,
            IFNULL(SUM(shifujine), 0) AS totalAmount
        FROM baomingjiaofei
        WHERE 1 = 1
        <if test="xueyuanId != null">
            AND xueyuanid = #{xueyuanId}
        </if>
        <if test="jiazhangId != null">
            AND jiazhangid = #{jiazhangId}
        </if>
        GROUP BY jiaofeizhuangtai
    </select>
</mapper>
